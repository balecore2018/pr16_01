<Page x:Class="pr16v2.Pages.Parents"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr16v2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="1100" d:DesignWidth="800"
      Title="Parents">

    <Grid Background="#F8F9FA">
        <Grid Margin="0,0,0,1040" Background="White">
            <Image HorizontalAlignment="Left" Height="40" Margin="10,10,0,0" VerticalAlignment="Top" Width="40" Source="/Images/logo.jpg"/>
            <Label Content="Электронная приемная компания" HorizontalAlignment="Left" Margin="55,1,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="19"/>
            <Label Content="Пермского авиационного техникума им. А. Д. Швецова" HorizontalAlignment="Left" Margin="55,24,0,0" VerticalAlignment="Top"/>
        </Grid>
        <Grid Margin="0,60,0,-0.4">
            <Label Content="Если родитель один, заполнить на одного родителя" 
       HorizontalAlignment="Left" 
       Margin="32,36,0,0"
       VerticalAlignment="Top"
       Background="{x:Null}" 
       FontSize="10"
       Foreground="Red"/>
            <Label Content="Сведения о родителях (законных представителях)" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
            <TextBox Margin="10,123,10,893" Height="24"/>
            <Button Content="Продолжить" HorizontalAlignment="Right" Margin="0,0,10,10" VerticalAlignment="Bottom" Width="150" Height="25"/>
            <Label Content="ФИО (полностью)" HorizontalAlignment="Left" Margin="10,97,0,0" VerticalAlignment="Top"/>
            <Label Content="Мать (или законный представитель):" HorizontalAlignment="Left" Margin="10,64,0,0" VerticalAlignment="Top" FontStyle="Italic"/>
            <TextBox Margin="10,183,10,833" Height="24"/>
            <Label Content="Дата рождения:" HorizontalAlignment="Left" Margin="10,157,0,0" VerticalAlignment="Top"/>
            <TextBox Margin="10,243,10,773" Height="24"/>
            <Label Content="Место работы:" HorizontalAlignment="Left" Margin="10,217,0,0" VerticalAlignment="Top"/>
            <TextBox Margin="10,303,10,713" Height="24"/>
            <Label Content="Должность:" HorizontalAlignment="Left" Margin="10,277,0,0" VerticalAlignment="Top"/>
            <TextBox Margin="10,358,10,658" Height="24"/>
            <Label Content="Место жительства:" HorizontalAlignment="Left" Margin="10,332,0,0" VerticalAlignment="Top"/>
            <TextBox Margin="10,436,429,580" Height="24"/>
            <Label Content="Домашний телефон" HorizontalAlignment="Left" Margin="10,390,0,0" VerticalAlignment="Top"/>
            <Label Content="(при наличии)" 
                HorizontalAlignment="Left" 
                Margin="32,413,0,0"
                VerticalAlignment="Top"
                Background="{x:Null}" 
                FontSize="10"
                Foreground="Red"/>
            <TextBox Margin="400,436,39,580" Height="24"/>
            <Label Content="Мобильный телефон:" HorizontalAlignment="Left" Margin="402,390,0,0" VerticalAlignment="Top"/>
            <Label Content="(при наличии)" 
                HorizontalAlignment="Left" 
                Margin="424,413,0,0"
                VerticalAlignment="Top"
                Background="{x:Null}" 
                FontSize="10"
                Foreground="Red"/>
            <CheckBox Content="Настоящим подтверждаю, что персональные данные на третью" HorizontalAlignment="Left" Margin="10,468,0,0" VerticalAlignment="Top" Height="17"/>
            <TextBox Margin="10,554,10,462" Height="24"/>
            <Label Content="ФИО (полностью)" HorizontalAlignment="Left" Margin="10,528,0,0" VerticalAlignment="Top"/>
            <Label Content="Отец (или законный представитель):" HorizontalAlignment="Left" Margin="10,495,0,0" VerticalAlignment="Top" FontStyle="Italic"/>
            <TextBox Margin="10,614,10,402" Height="24"/>
            <Label Content="Дата рождения:" HorizontalAlignment="Left" Margin="10,588,0,0" VerticalAlignment="Top"/>
            <TextBox Margin="10,674,10,342" Height="24"/>
            <Label Content="Место работы:" HorizontalAlignment="Left" Margin="10,648,0,0" VerticalAlignment="Top"/>
            <TextBox Margin="10,734,10,282" Height="24"/>
            <Label Content="Должность:" HorizontalAlignment="Left" Margin="10,708,0,0" VerticalAlignment="Top"/>
            <TextBox Margin="10,789,10,227" Height="24"/>
            <Label Content="Место жительства:" HorizontalAlignment="Left" Margin="10,763,0,0" VerticalAlignment="Top"/>
            <TextBox Margin="10,867,429,149" Height="24"/>
            <Label Content="Домашний телефон" HorizontalAlignment="Left" Margin="10,821,0,0" VerticalAlignment="Top"/>
            <Label Content="(при наличии)" 
                HorizontalAlignment="Left" 
                Margin="32,844,0,0"
                VerticalAlignment="Top"
                Background="{x:Null}" 
                FontSize="10"
                Foreground="Red"/>
            <TextBox Margin="402,867,37,149" Height="24"/>
            <Label Content="Мобильный телефон:" HorizontalAlignment="Left" Margin="402,821,0,0" VerticalAlignment="Top"/>
            <Label Content="(при наличии)" 
                HorizontalAlignment="Left" 
                Margin="424,844,0,0"
                VerticalAlignment="Top"
                Background="{x:Null}" 
                FontSize="10"
                Foreground="Red"/>
            <CheckBox Content="Настоящим подтверждаю, что персональные данные на третью" HorizontalAlignment="Left" Margin="10,899,0,0" VerticalAlignment="Top" Height="17"/>
        </Grid>
    </Grid>
</Page>
