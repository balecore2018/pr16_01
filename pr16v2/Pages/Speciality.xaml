<Page x:Class="pr16v2.Pages.Speciality"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr16v2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Speciality">

    <Grid Background="#F8F9FA">
        <Grid Margin="0,0,0,540" Background="White">
            <Image HorizontalAlignment="Left" Height="40" Margin="10,10,0,0" VerticalAlignment="Top" Width="40" Source="/Images/logo.jpg"/>
            <Label Content="Электронная приемная компания" HorizontalAlignment="Left" Margin="55,1,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="19"/>
            <Label Content="Пермского авиационного техникума им. А. Д. Швецова" HorizontalAlignment="Left" Margin="55,24,0,0" VerticalAlignment="Top"/>
        </Grid>
        <Grid Margin="0,60,0,-0.4">
            <Label Content="Специальность" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
            <Label Content="Выберите специальность, на которой желаете учиться:" HorizontalAlignment="Left" Margin="10,41,0,0" VerticalAlignment="Top"/>
            <Label Content="Можете выбрать несколько специальностей" HorizontalAlignment="Left" Margin="20,67,0,0" VerticalAlignment="Top" Background="{x:Null}" FontSize="10" Foreground="Red"/>
            <CheckBox Content="Авиационные приборы и комплексы" HorizontalAlignment="Left" Margin="22,91,0,0" VerticalAlignment="Top" Checked="CheckBox_Checked"/>
            <CheckBox Content="Аддитивные технологии" HorizontalAlignment="Left" Margin="22,106,0,0" VerticalAlignment="Top"/>
            <Label Content="Выберите один из вариантов:" HorizontalAlignment="Left" Margin="19,333,0,0" VerticalAlignment="Top" Background="{x:Null}" FontSize="10" Foreground="Red"/>
            <Button Content="Продолжить" HorizontalAlignment="Right" Margin="0,0,10,10" VerticalAlignment="Bottom" Width="150" Height="25"/>
            <RadioButton Content="впервые" HorizontalAlignment="Left" Margin="22,361,0,0" VerticalAlignment="Top" Checked="RadioButton_Checked"/>
            <RadioButton Content="не впервые" HorizontalAlignment="Left" Margin="22,376,0,0"  VerticalAlignment="Top" Checked="RadioButton_Checked"/>
            <Label Content="Среднее профессиональное образование получаю:" HorizontalAlignment="Left" Margin="11,307,0,0" VerticalAlignment="Top"/>
            <CheckBox Content="Информационные системы и программирование" HorizontalAlignment="Left" Margin="22,122,0,0" VerticalAlignment="Top"/>
            <CheckBox Content="ИСВ" HorizontalAlignment="Left" Margin="22,138,0,0" VerticalAlignment="Top"/>
            <CheckBox Content="Компьютерные системы и комплексы" HorizontalAlignment="Left" Margin="22,154,0,0" VerticalAlignment="Top"/>
            <CheckBox Content="Литейное производство" HorizontalAlignment="Left" Margin="22,170,0,0" VerticalAlignment="Top"/>
            <CheckBox Content="Мехатроника" HorizontalAlignment="Left" Margin="22,186,0,0" VerticalAlignment="Top"/>
            <CheckBox Content="Прикладная информатика" HorizontalAlignment="Left" Margin="22,202,0,0" VerticalAlignment="Top"/>
            <CheckBox Content="Производство авиационных двигателей" HorizontalAlignment="Left" Margin="22,218,0,0" VerticalAlignment="Top"/>
            <CheckBox Content="Радиоэлектронные приборные устр-ва" HorizontalAlignment="Left" Margin="22,234,0,0" VerticalAlignment="Top"/>
            <CheckBox Content="Технология машиностроения" HorizontalAlignment="Left" Margin="22,250,0,0" VerticalAlignment="Top"/>
            <CheckBox Content="Технология металлообрабатывающего произ-ва" HorizontalAlignment="Left" Margin="22,265,0,0" VerticalAlignment="Top"/>
            <CheckBox Content="Управление качеством продукции, процессов и услуг" HorizontalAlignment="Left" Margin="22,279,0,0" VerticalAlignment="Top"/>
            <CheckBox Content="С лицензией на право осуществления образовательной деятельности, свидетельством о государственной аккредитации," HorizontalAlignment="Left" Margin="22,407,0,0" VerticalAlignment="Top" Height="17"/>
            <Label Content="правилами приёма и правилами внутреннего распорядка обучающихся в данном образовательном учреждении, с Уставом" HorizontalAlignment="Left" Margin="25,421,0,0" VerticalAlignment="Top"/>
            <Label Content="Техникума ознакомлен(а)" HorizontalAlignment="Left" Margin="25,441,0,0" VerticalAlignment="Top"/>
            <CheckBox Content="С датой представления оригиналов документов ознакомлен(а)" HorizontalAlignment="Left" Margin="22,467,0,0" VerticalAlignment="Top" Height="17" Checked="CheckBox_Checked"/>
        </Grid>
    </Grid>
</Page>
