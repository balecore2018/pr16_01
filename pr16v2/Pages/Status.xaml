<Page x:Class="pr16v2.Pages.Status"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr16v2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Status">

    <Grid Background="#F8F9FA">
        <Grid Margin="0,0,0,349.6" Background="White">
            <Image HorizontalAlignment="Left" Height="40" Margin="10,10,0,0" VerticalAlignment="Top" Width="40" Source="/Images/logo.jpg"/>
            <Label Content="Электронная приемная компания" HorizontalAlignment="Left" Margin="55,1,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="19"/>
            <Label Content="Пермского авиационного техникума им. А. Д. Швецова" HorizontalAlignment="Left" Margin="55,24,0,0" VerticalAlignment="Top"/>
        </Grid>
        <Grid Margin="0,60,0,-0.4">
            <Label Content="Статус" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
            <Label Content="Имею статус:" HorizontalAlignment="Left" Margin="10,41,0,0" VerticalAlignment="Top"/>
            <Label Content="Отметить при наличии" HorizontalAlignment="Left" Margin="20,67,0,0" VerticalAlignment="Top" Background="{x:Null}" FontSize="10" Foreground="Red"/>
            <CheckBox Content="ребенок-сирота/ребенок без родителей" HorizontalAlignment="Left" Margin="22,91,0,0" VerticalAlignment="Top"/>
            <CheckBox Content="инвалид" HorizontalAlignment="Left" Margin="22,106,0,0" VerticalAlignment="Top"/>
            <Label Content="Выберите один из вариантов:" HorizontalAlignment="Left" Margin="20,167,0,0" VerticalAlignment="Top" Background="{x:Null}" FontSize="10" Foreground="Red"/>
            <Label Content="Прикрепите сканы 1-ой и 2-ой страниц приписного удостоверения или военного билета при их наличии" HorizontalAlignment="Left" Margin="10,234,0,0" VerticalAlignment="Top"/>
            <TextBox Margin="12,286,107,80" Height="24"/>
            <Button Content="Выбрать..." HorizontalAlignment="Right" Margin="0,0,10,80" VerticalAlignment="Bottom" Width="92" Height="24"/>
            <Label Content="(Формат документа должен быть PNG,JPEG или PDF, а максимальный размер каждого файла 5 МБ)" HorizontalAlignment="Left" Margin="44,260,0,0" VerticalAlignment="Top" Background="{x:Null}" FontSize="10" Foreground="Red"/>
            <Button Content="Продолжить" HorizontalAlignment="Right" Margin="0,0,10,50" VerticalAlignment="Bottom" Width="150" Height="25"/>
            <CheckBox Content="Малообеспеченный" HorizontalAlignment="Left" Margin="22,121,0,0" VerticalAlignment="Top"/>
            <RadioButton Content="имею" HorizontalAlignment="Left" Margin="23,195,0,0" VerticalAlignment="Top" Checked="RadioButton_Checked"/>
            <RadioButton Content="не имею" HorizontalAlignment="Left" Margin="23,210,0,0" VerticalAlignment="Top" Checked="RadioButton_Checked"/>
            <Label Content="Приписное удостоверение:" HorizontalAlignment="Left" Margin="12,141,0,0" VerticalAlignment="Top"/>
        </Grid>
    </Grid>
</Page>
